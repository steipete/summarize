source "https://rubygems.org"

# Local preview for the docs site. GitHub Pages builds the same source via
# actions/jekyll-build-pages; this bundle keeps `pnpm docs:serve` usable on
# current local Ruby versions.
gem "jekyll", "~> 4.4"
gem "rouge", "~> 4.7"
gem "webrick", "~> 1.9"

group :jekyll_plugins do
  gem "jekyll-relative-links", "~> 0.6"
end

# Tzinfo + WDM are needed on Windows; harmless elsewhere.
platforms :mingw, :x64_mingw, :mswin, :jruby do
  gem "tzinfo", ">= 1", "< 3"
  gem "tzinfo-data"
end

gem "wdm", "~> 0.1.1", platforms: [:mingw, :x64_mingw, :mswin]
