{
  "name": "@steipete/summarize-core",
  "version": "0.12.1",
  "description": "Summarize core library (content extraction + prompts).",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/esm/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js"
    },
    "./content": {
      "types": "./dist/types/content/index.d.ts",
      "import": "./dist/esm/content/index.js"
    },
    "./content/url": {
      "types": "./dist/types/content/url.d.ts",
      "import": "./dist/esm/content/url.js"
    },
    "./content/local-file": {
      "types": "./dist/types/content/local-file.d.ts",
      "import": "./dist/esm/content/local-file.js"
    },
    "./prompts": {
      "types": "./dist/types/prompts/index.d.ts",
      "import": "./dist/esm/prompts/index.js"
    },
    "./processes": {
      "types": "./dist/types/processes.d.ts",
      "import": "./dist/esm/processes.js"
    },
    "./language": {
      "types": "./dist/types/language.d.ts",
      "import": "./dist/esm/language.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  },
  "dependencies": {
    "@fal-ai/client": "^1.9.4",
    "@mozilla/readability": "0.6.0",
    "cheerio": "^1.2.0",
    "es-toolkit": "^1.45.1",
    "jsdom": "29.0.2",
    "sanitize-html": "^2.17.1"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.4.0",
    "@types/sanitize-html": "^2.16.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.25.0+sha512.5e82639027af37cf832061bcc6d639c219634488e0f2baebe785028a793de7b525ffcd3f7ff574f5e9860654e098fe852ba8ac5dd5cefe1767d23a020a92f501"
}
